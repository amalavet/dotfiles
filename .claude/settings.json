{
  "permissions": {
    "allow": [
      "Bash(gh issue view:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Read(*)",
      "Bash(ls:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run test:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Write(./src/*)",
      "Write(./tests/*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push:*)",
      "Bash(sudo:*)",
      "Bash(chmod:*)",
      "Read(./.env)"
    ]
  },
  "model": "sonnet[1m]",
  "enabledPlugins": {
    "example-skills@anthropic-agent-skills": true,
    "grafana-tech-writing@grafana-ai-kit": true,
    "grafana-core@grafana-ai-kit": true,
    "grafana-delegator@grafana-ai-kit": true,
    "grafana-docker-migration@grafana-ai-kit": true,
    "grafana-enghub@grafana-ai-kit": true,
    "grafana-engineering@grafana-ai-kit": true,
    "grafana-gtd@grafana-ai-kit": true,
    "grafana-k6@grafana-ai-kit": true,
    "grafana-mobile@grafana-ai-kit": true,
    "grafana-o11y@grafana-ai-kit": true,
    "grafana-o11y-pm@grafana-ai-kit": true,
    "grafana-product@grafana-ai-kit": true,
    "document-skills@anthropic-agent-skills": true,
    "claude-api@anthropic-agent-skills": true,
    "grafana-app-sdk@grafana-ai-kit": true
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    }
  }
}
